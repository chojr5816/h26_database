문제 22 [기업 프로젝트 데이터베이스]
(1)테이블을 생성하는 CREATE문과 데이터를 삽입하는 INSERT문을 작성하시오. 테이블의 데이터 타입은 임의로 정하고, 데이터는 다음 질의의 결과가 나오도록 삽입한다.
-- 1. 부서(Department) 테이블
CREATE TABLE Department (
    depno NUMBER PRIMARY KEY,        
    deptname VARCHAR2(50) NOT NULL, 
    manager VARCHAR2(50)            
);

-- 2. 사원(Employee) 테이블
CREATE TABLE Employee (
    empno NUMBER PRIMARY KEY,        
    name VARCHAR2(50) NOT NULL,      
    phoneno VARCHAR2(20),            
    address VARCHAR2(100),           
    sex CHAR(1),                     
    position VARCHAR2(30),           
    depno NUMBER,                    
    FOREIGN KEY (depno) REFERENCES Department(depno)
);

-- 3. 프로젝트(Project) 테이블
CREATE TABLE Project (
    projno NUMBER PRIMARY KEY,      
    projname VARCHAR2(100) NOT NULL, 
    depno NUMBER,                    
    FOREIGN KEY (depno) REFERENCES Department(depno)
);

-- 4. 참여(Works) 테이블
CREATE TABLE Works (
    empno NUMBER,                    
    projno NUMBER,                   
    hours_worked NUMBER(5, 2),       
    PRIMARY KEY (empno, projno),     
    FOREIGN KEY (empno) REFERENCES Employee(empno),
    FOREIGN KEY (projno) REFERENCES Project(projno)
);

