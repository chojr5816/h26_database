FROM Employee E, Department D, Works W
WHERE E.empno = W.empno AND E.depno = D.depno
ORDER BY D.deptname ASC, E.name ASC;

(8)2명 이상의 사원이 참여한 프로젝트의 번호, 이름, 사원의 수를 보이시오
