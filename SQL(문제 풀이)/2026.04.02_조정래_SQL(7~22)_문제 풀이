문제 21 [판매원 데이터베이스]

(1) 테이블을 생성하는 CREATE 문과 데이터를 삽입하는 INSERT문을 작성하시오. 테이블의 데이터 타입은 임의로 정하고, 데이터는 다음 질의의 결과가 나오도록 삽입한다.

-- 1. Salesperson 테이블 생성
CREATE TABLE Salesperson (
    name VARCHAR2(50) PRIMARY KEY,
    age NUMBER(3),
    salary NUMBER(10)
);

-- 2. Customer 테이블 생성
CREATE TABLE Customer (
    name VARCHAR2(50) PRIMARY KEY,
    city VARCHAR2(50),
    industrytype VARCHAR2(50)
);

-- 3. Order 테이블 생성 (외래키 포함)
CREATE TABLE Orders (
    number NUMBER PRIMARY KEY,
    custname VARCHAR2(50),
    salesperson VARCHAR2(50),
    amount NUMBER(10),
    CONSTRAINT fk_customer FOREIGN KEY (custname) REFERENCES Customer(name),
    CONSTRAINT fk_salesperson FOREIGN KEY (salesperson) REFERENCES Salesperson(name)
);


