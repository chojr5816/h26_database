문제 20.[극장데이터베이스] 
-- 1. 극장 테이블
CREATE TABLE 극장 (
    극장번호 INT PRIMARY KEY,
    극장이름 VARCHAR(20),
    위치 VARCHAR(20)
);

-- 2. 고객 테이블
CREATE TABLE 고객 (
    고객번호 INT PRIMARY KEY,
    이름 VARCHAR(20),
    주소 VARCHAR(20)
);

-- 3. 상영관 테이블 (제약조건 포함)
CREATE TABLE 상영관 (
    극장번호 INT,
    상영관번호 INT,
    영화제목 VARCHAR(50),
    가격 INT,
    좌석수 INT,
    PRIMARY KEY (극장번호, 상영관번호),
    FOREIGN KEY (극장번호) REFERENCES 극장(극장번호),
    -- 제약조건: 영화가격은 20,000원을 넘지 않아야 한다.
    CHECK (가격 <= 20000),
    -- 제약조건: 상영관번호는 1~10 사이이다.
    CHECK (상영관번호 BETWEEN 1 AND 10)
);

-- 4. 예약 테이블 (복합 제약조건 포함)
CREATE TABLE 예약 (
    극장번호 INT,
    상영관번호 INT,
    고객번호 INT,
    좌석번호 INT,
    날짜 DATE,
    PRIMARY KEY (극장번호, 상영관번호, 고객번호),
    FOREIGN KEY (극장번호, 상영관번호) REFERENCES 상영관(극장번호, 상영관번호),
    FOREIGN KEY (고객번호) REFERENCES 고객(고객번호),
    -- 제약조건: 같은 사람이 같은 좌석번호를 두 번 예약하지 않아야 한다.
    -- (이미 PRIMARY KEY로 설정되어 중복 예약은 방지되지만, 좌석 기준 유니크 설정 추가 가능)
    UNIQUE (고객번호, 좌석번호)
);

