③2025년 9월 1일의 극장별 평균 관람 고객 수를 보이시오
SELECT 극장번호, avg(고객수) as "평균 관람 고객 수"
FROM (
    select 극장번호, 날짜, count(고객번호) as 고객수
    from 예약
    where 날짜 = to_date('2025-09-01', 'YYYY-MM-DD')
    group by 극장번호, 날짜
)
group by 극장번호;

④2025년 9월 1일에 가장 많은 고객이 관람한 영화를 보이시오
select s.영화제목
from 상영관 s
join 예약 r on s.극장번호 = r.극장번호 and s.상영관번호 = r.상영관번호
where r.날짜 = to_date('2025-09-01', 'yyyy-mm-dd')
group by s.영화제목
having count(r.고객번호) = (
	select max(count(r2.고객번호))
	from 예약 r2
	join 상영관 s2 on r2.극장번호 = s2.극장번호 and r2.상영관번호 = s2.상영관번호
	where r2.날짜 = to_date('2025-09-01', 'yyyy-mm-dd')
	group by s2.영화제목
);

