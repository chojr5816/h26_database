1) 영화 가격이 9,000원 이상인 상영관의 극장번호를 추출하시오

SELECT 극장번호		(3번)
FROM 상영관		(1번)
WHERE 가격 >=9000;  (2번)

2)극장별 상영관(두 테이블 조인)

SELECT*				(3번)
FROM 극장, 상영관  		(1번)
WHERE 극장.극장번호 = 상영관.극장번호;	(2번) 

3)영화 가격이 10,000원 이상인 영화를 상영하는 극장이름

SELECT DISTINCT t.극장이름  (3번)
FROM 극장 t  JOIN 상영관 s ON t.극장번호 = s.극장번호 (1번)
WHERE s.가격 >=10000 (2번)

4)예약 날짜가 2024년 1월 1일 이후인 고객 정보와 예약 내용-- (예약이 없는 고객도 포함→ LEFT OUTER JOIN)

SELECT c.고객번호, c.이름, c.주소, r.예약번호, r.극장번호, r.상영관번호, r.좌석번호, r.날짜  (3번)
FROM 고객 c LEFT OUTER JOIN 예약 r    (1번) 
ON c.고객번호 = r.고객번호 AND r.날짜 > TO_DATE('2024-01-01','YYYY-MM-DD');  (2번)

5) 강남에 있는 모든 극장을 예약한 고객의 이름과 극장번호를 출력

SELECT DISTINCT c.이름 t.극장번호   (4번)
FROM 고객 c    (1번)
WHERE NOT EXISTS    (3번)
 (SELECT t.극장번호 FROM 극장 t WHERE t.위치 ='강남’ MINUS SELECT r.극장번호 FROM 예약 r WHERE r.고객번호 = c.고객번호);     (2번)

