13. 학년을 입력받아 해당 학년 학생들의 전공별 평균 성적을 출력하는 프로시저를 작성하시오.

CREATE OR REPLACE PROCEDURE GetDeptAvgByYear(v_학년 IN 학생.학년%TYPE)
IS
    CURSOR a_cursor IS
        SELECT h.전공, AVG(s.성적) as 평점
        FROM 학생 h JOIN 수강 s ON h.학번 = s.학번
        WHERE h.학년 = v_학년 GROUP BY h.전공;
BEGIN
    FOR r IN a_cursor LOOP
        DBMS_OUTPUT.PUT_LINE('전공: ' || r.전공 || ', 평균: ' || r.평점);
    END LOOP;
END;
/

