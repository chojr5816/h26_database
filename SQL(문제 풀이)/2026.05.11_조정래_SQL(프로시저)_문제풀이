9. 수강 학기를 입력받아 해당 학기에 수강 인원이 가장 많은 과목 이름과 인원수를 출력하는 프로시저를 작성하시오. 

CREATE OR REPLACE PROCEDURE GetPopularSubject(v_학기 IN 수강.수강학기%TYPE)
IS
    v_이름 과목.과목이름%TYPE; v_인원 NUMBER;
BEGIN
    SELECT 과목이름, 인원 INTO v_이름, v_인원
    FROM (SELECT k.과목이름, COUNT(*) as 인원
          FROM 수강 s JOIN 과목 k ON s.과목코드 = k.과목코드
          WHERE s.수강학기 = v_학기 GROUP BY k.과목이름 ORDER BY 인원 DESC)
    WHERE ROWNUM = 1;
    DBMS_OUTPUT.PUT_LINE('과목: ' || v_이름 || ', 인원: ' || v_인원);
END;
/

