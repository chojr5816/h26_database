10. 특정 주문금액 이상의 주문을 한 고객의 custid, name, 주문 건수를 출력하는 프로시저를 작성하시오.

CREATE OR REPLACE PROCEDURE GetHighValueOrders(v_min_price IN NUMBER)
IS
    CURSOR result_cursor IS
        SELECT c.custid, c.name, COUNT(o.orderid) as cnt
        FROM Customer c
        JOIN Orders o ON c.custid = o.custid
        WHERE o.saleprice >= v_min_price
        GROUP BY c.custid, c.name;
BEGIN
    FOR r IN result_cursor LOOP
        DBMS_OUTPUT.PUT_LINE('ID: ' || r.custid || ' | 이름: ' || r.name || ' | 건수: ' || r.cnt);
    END LOOP;
END;
/

