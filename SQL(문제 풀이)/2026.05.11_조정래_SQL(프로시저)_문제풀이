14. 수강 신청 시 동일 학번과 과목코드로 이미 수강 내역이 존재하면 '이미 수강 중입니다'
메시지를 출력하고 삽입을 중단하는 프로시저를 작성하시오. 

CREATE OR REPLACE PROCEDURE EnrollClass(v_학번 IN 수강.학번%TYPE, v_코드 IN 수강.과목코드%TYPE)
IS
    v_cnt NUMBER;
BEGIN
    SELECT COUNT(*) INTO v_cnt FROM 수강 WHERE 학번 = v_학번 AND 과목코드 = v_코드;
    IF v_cnt > 0 THEN
        DBMS_OUTPUT.PUT_LINE('이미 수강 중입니다.');
    ELSE
        INSERT INTO 수강(과목코드, 학번) VALUES (v_코드, v_학번);
        COMMIT;
    END IF;
END;
/

15. 특정 수강 학기를 입력받아 성적이 NULL인 학생의 학번, 이름, 과목 이름을 출력하고 성적 미입력 건수를 OUT 매개변수로 반환하는 프로시저를 작성하시오.

CREATE OR REPLACE PROCEDURE GetNoGradeStudents(v_학기 IN 수강.수강학기%TYPE, v_count OUT NUMBER)
IS
    CURSOR n_cursor IS
        SELECT h.학번, h.이름, k.과목이름
        FROM 수강 s JOIN 학생 h ON s.학번 = h.학번 JOIN 과목 k ON s.과목코드 = k.과목코드
        WHERE s.수강학기 = v_학기 AND s.성적 IS NULL;
BEGIN
    v_count := 0;
    FOR r IN n_cursor LOOP
        DBMS_OUTPUT.PUT_LINE('미입력: ' || r.이름 || '(' || r.과목이름 || ')');
        v_count := v_count + 1;
    END LOOP;
END;
/

