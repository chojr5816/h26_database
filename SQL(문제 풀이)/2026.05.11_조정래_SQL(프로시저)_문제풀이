CREATE OR REPLACE PROCEDURE GetStudentInfo(v_학번 IN 학생.학번%TYPE)
IS
    v_이름 학생.이름%TYPE; v_전공 학생.전공%TYPE; v_학년 학생.학년%TYPE;
