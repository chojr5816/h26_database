FROM Orders
WHERE salesperson = 'Tom';

문제 9.
이름이 'S'로 시작하는 판매원의 이름, 나이, 급여를 보여주는
읽기 전용 뷰 v_s_salesperson을 작성하시오. 

CREATE VIEW v_s_salesperson AS
