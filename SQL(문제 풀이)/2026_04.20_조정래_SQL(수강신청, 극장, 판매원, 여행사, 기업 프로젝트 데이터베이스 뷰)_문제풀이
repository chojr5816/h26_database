교재 127 chap2장 연습문제 17번 기준
[수강신청 데이터베이스]
학생(학번, 이름, 전공, 학년)
수강(과목코드, 학번, 수강학기, 성적)
과목(과목코드, 과목이름, 강의실, 요일, 담당교수)

(1)학생 수강 전체 현황 뷰를 작성하시오.
(학생정보+수강 과목+성적을 한 분에 확인가능하도록 작성)

CREATE VIEW V_STUDENT_ENROLLMENT_STATUS AS
SELECT S.학번, S.이름, S.전공, S.학년, C.과목이름, E.수강학기, E.성적
FROM 학생 S
JOIN 수강 E ON S.학번 = E.학번
JOIN 과목 C ON E.과목코드 = C.과목코드;

(2)각 학생별 평균 성적 뷰를 작성하시오.
(각 학생의 전체 수강 과목 평균 성적 계산 뷰)

CREATE VIEW V_STUDENT_AVG_GRADE AS
SELECT 학번, AVG(성적) AS 평균성적
FROM 수강
GROUP BY 학번;

(3)과목별 수강 인원 및 평균 성적 뷰를 작성하시오.
(각 과목의 수강 인원과 평균, 최고,최저 성적 통계 뷰)

CREATE VIEW V_COURSE_STATISTICS AS
SELECT 과목코드, 
       COUNT(학번) AS 수강인원, 
       AVG(성적) AS 평균성적, 
       MAX(성적) AS 최고성적, 
       MIN(성적) AS 최저성적
FROM 수강
GROUP BY 과목코드;

(4)성적 우수 학생 뷰를 작성하시오.(평균 90점 이상)
(평균 성적이 90점 이상이 우수 학생만 조회하는 뷰)

CREATE VIEW V_EXCELLENT_STUDENTS AS
SELECT 학번, AVG(성적) AS 평균성적
FROM 수강
GROUP BY 학번
HAVING AVG(성적) >= 90;

(5)전공 별 수강 통계 뷰를 작성하시오. (전공별 총 수강 건수와 전공 평균 성적 비교 뷰)

CREATE VIEW V_MAJOR_STATISTICS AS
SELECT S.전공, 
       COUNT(E.과목코드) AS 총수강건수, 
       AVG(E.성적) AS 전공평균성적
FROM 학생 S
JOIN 수강 E ON S.학번 = E.학번
GROUP BY S.전공;

(6)학기별 수강 현황 뷰를 작성하시오.

CREATE VIEW V_SEMESTER_ENROLLMENT AS
SELECT 수강학기, 과목코드, COUNT(학번) AS 수강학생수
FROM 수강
GROUP BY 수강학기, 과목코드;

(7)미수강 학생 뷰를 작성하시오.

CREATE VIEW V_NON_ENROLLED_STUDENTS AS
SELECT S.학번, S.이름, S.전공
FROM 학생 S
LEFT JOIN 수강 E ON S.학번 = E.학번
WHERE E.학번 IS NULL;

(8)담당 교수별 강의 및 수강 현황 뷰를 작성하시오.
 과목별 담당 과목 수와 총 수강 학생수를 집계하는 뷰)

CREATE VIEW V_PROFESSOR_LECTURE_STATUS AS
SELECT 담당교수, 
       -- C.과목코드 처럼 어떤 테이블의 컬럼인지 명시해야 합니다.
       COUNT(DISTINCT C.과목코드) AS 담당과목수, 
       COUNT(E.학번) AS 총수강학생수
FROM 과목 C
LEFT JOIN 수강 E ON C.과목코드 = E.과목코드
GROUP BY 담당교수;

(9)학년별 수강 과목 수 및 평균 성적 뷰를 작성하시오.
(학년에 따른 수강 부담과 성적 추이를 파악하는 뷰 작성)

CREATE VIEW V_GRADE_LEVEL_STATISTICS AS
SELECT S.학년, 
       COUNT(E.과목코드) / COUNT(DISTINCT S.학번) AS 학생당평균수강수, 
       AVG(E.성적) AS 학년평균성적
FROM 학생 S
JOIN 수강 E ON S.학번 = E.학번
GROUP BY S.학년;
(10)성적 미입력(NULL) 수강 내역 뷰를 작성하시오.
(성적이 아직 입력되지 않은 수강 내역 관리용이다.)

CREATE VIEW V_MISSING_GRADES AS
SELECT S.학번, S.이름, E.과목코드, E.수강학기
FROM 학생 S
JOIN 수강 E ON S.학번 = E.학번
WHERE E.성적 IS NULL;

교재 126 chap2장 연습문제 16번 극장데이터베이스 기준
위 데이터베이스 정보를 가지고 문제에 대한 뷰를 작성한다.  테이블 구조 확인
극장(극장번호, 극장이름, 위치)
상영관(극장번호, 상영관번호, 영화제목, 가격, 좌석수)
예약(극장번호, 상영관번호, 고객번호, 좌석번호, 날짜)
고객(고객번호, 이름, 주소)

 뷰 생성 질의어 15개
1. 전체 상영 정보 통합 뷰를 작성하시오.
(극장 + 상영관 + 영화 정보를 한눈에 확인 가능하도록 작성)

CREATE VIEW V_TOTAL_SCREENING_INFO AS
SELECT T.극장번호, T.극장이름, T.위치, S.상영관번호, S.영화제목, S.가격, S.좌석수
FROM 극장 T
JOIN 상영관 S ON T.극장번호 = S.극장번호;

2 .예약 전체 현황 뷰를 작성하시오
(고객이 어떤 극장·상영관·영화를 예약했는지 통합 조회하도록 작성)

CREATE VIEW V_RESERVATION_FULL_STATUS AS
SELECT R.고객번호, C.이름, S.영화제목, T.극장이름, S.상영관번호, R.좌석번호, R.날짜
FROM 예약 R
JOIN 고객 C ON R.고객번호 = C.고객번호
JOIN 상영관 S ON R.극장번호 = S.극장번호 AND R.상영관번호 = S.상영관번호
JOIN 극장 T ON S.극장번호 = T.극장번호;

3. 극장별 상영 영화 목록 뷰를 작성하시오
 (각 극장에서 상영 중인 영화와 가격, 좌석수 조회)

CREATE VIEW V_THEATER_MOVIE_LIST AS
SELECT T.극장이름, S.영화제목, S.가격, S.좌석수
FROM 극장 T
JOIN 상영관 S ON T.극장번호 = S.극장번호;

4. 고객별 예약 내역 뷰를 작성하시오
 (고객별 예약한 영화 목록과 날짜, 금액 조회가능한 뷰)

CREATE VIEW V_CUSTOMER_RESERVATION_HISTORY AS
SELECT C.이름, S.영화제목, R.날짜, S.가격
FROM 고객 C
JOIN 예약 R ON C.고객번호 = R.고객번호
JOIN 상영관 S ON R.극장번호 = S.극장번호 AND R.상영관번호 = S.상영관번호;

5. 상영관별 예약 인원 및 잔여 좌석 뷰를 작성하시오
 (상영관의 총 좌석 대비 예약 현황과 잔여 좌석 계산)

CREATE VIEW V_SEAT_AVAILABILITY AS
SELECT S.극장번호, S.상영관번호, S.영화제목, S.좌석수 AS 총좌석, 
       COUNT(R.좌석번호) AS 예약인원, 
       (S.좌석수 - COUNT(R.좌석번호)) AS 잔여좌석
FROM 상영관 S
LEFT JOIN 예약 R ON S.극장번호 = R.극장번호 AND S.상영관번호 = R.상영관번호
GROUP BY S.극장번호, S.상영관번호, S.영화제목, S.좌석수;

6. 극장별 총 예약 수 및 매출 뷰를 작성하시오
 (극장별 총 예약 건수와 누적 매출 집계를 볼 수 있는 뷰)

CREATE VIEW V_THEATER_SALES AS
SELECT T.극장이름, COUNT(R.고객번호) AS 총예약수, SUM(S.가격) AS 총매출
FROM 극장 T
JOIN 상영관 S ON T.극장번호 = S.극장번호
JOIN 예약 R ON S.극장번호 = R.극장번호 AND S.상영관번호 = R.상영관번호
GROUP BY T.극장이름;

7. 영화별 예약 현황 뷰를 작성하시오
 (영화 제목별 총 예약 인원과 총 매출 집계 뷰)

CREATE VIEW V_MOVIE_RESERVATION_STAT AS
SELECT S.영화제목, COUNT(R.고객번호) AS 총예약인원, SUM(S.가격) AS 총매출
FROM 상영관 S
LEFT JOIN 예약 R ON S.극장번호 = R.극장번호 AND S.상영관번호 = R.상영관번호
GROUP BY S.영화제목;

8. 날짜별 예약 현황 뷰를 작성하시오
(날짜별 예약 건수와 해당 날짜 매출 조회 가능한 뷰 작성)

CREATE VIEW V_DAILY_RESERVATION_STAT AS
SELECT R.날짜, COUNT(*) AS 예약건수, SUM(S.가격) AS 일일매출
FROM 예약 R
JOIN 상영관 S ON R.극장번호 = S.극장번호 AND R.상영관번호 = S.상영관번호
GROUP BY R.날짜;

9. 예약 이력이 없는 고객 뷰
(한 번도 예약한 적 없는 고객 조회하는 뷰 작성)

CREATE VIEW V_NEW_CUSTOMERS AS
SELECT C.고객번호, C.이름, C.주소
FROM 고객 C
LEFT JOIN 예약 R ON C.고객번호 = R.고객번호
WHERE R.고객번호 IS NULL;

10. 고객별 총 예약 횟수 및 결제 금액 뷰
(고객의 예약 활동 통계) (충성 고객 분석용)

CREATE VIEW V_CUSTOMER_LOYALTY AS
SELECT C.이름, COUNT(R.고객번호) AS 예약횟수, SUM(S.가격) AS 총결제금액
FROM 고객 C
LEFT JOIN 예약 R ON C.고객번호 = R.고객번호
LEFT JOIN 상영관 S ON R.극장번호 = S.극장번호 AND R.상영관번호 = S.상영관번호
GROUP BY C.고객번호, C.이름;

11. 가격이 가장 비싼 상영관 뷰를 작성하시오
 (티켓 가격 기준 상위 상영관 목록 조회하는 뷰 작성)

CREATE VIEW V_PREMIUM_THEATERS AS
SELECT 극장번호, 상영관번호, 영화제목, 가격
FROM 상영관
WHERE 가격 = (SELECT MAX(가격) FROM 상영관);

12. 위치별 극장 및 상영 현황 뷰
(지역(위치)별로 운영 중인 극장과 상영 영화 수 집계하는 뷰 작성)

CREATE VIEW V_LOCATION_STATUS AS
SELECT T.위치, COUNT(DISTINCT T.극장번호) AS 극장수, COUNT(S.영화제목) AS 상영영화수
FROM 극장 T
LEFT JOIN 상영관 S ON T.극장번호 = S.극장번호
GROUP BY T.위치;

13. 만석 상영관 뷰를 작성하시오
 (예약 좌석 수가 전체 좌석 수와 동일한 매진 상영관 조회)

CREATE VIEW V_FULLY_BOOKED_THEATERS AS
SELECT S.극장번호, S.상영관번호, S.영화제목
FROM 상영관 S
JOIN 예약 R ON S.극장번호 = R.극장번호 AND S.상영관번호 = R.상영관번호
GROUP BY S.극장번호, S.상영관번호, S.영화제목, S.좌석수
HAVING COUNT(R.좌석번호) >= S.좌석수;

14. 특정 날짜 예약 고객 상세 뷰를 작성하시오
( 날짜별 예약 고객 정보와 관람 영화 상세 조회)

CREATE VIEW V_DAILY_RESERVATION_DETAIL AS
SELECT R.날짜, C.이름 AS 고객명, S.영화제목, T.극장이름
FROM 예약 R
JOIN 고객 C ON R.고객번호 = C.고객번호
JOIN 상영관 S ON R.극장번호 = S.극장번호 AND R.상영관번호 = S.상영관번호
JOIN 극장 T ON S.극장번호 = T.극장번호;

15. 예약 없는 상영관 뷰
개설되었지만 예약이 한 건도 없는 상영관 조회

CREATE VIEW V_EMPTY_THEATERS AS
SELECT S.극장번호, S.상영관번호, S.영화제목
FROM 상영관 S
LEFT JOIN 예약 R ON S.극장번호 = R.극장번호 AND S.상영관번호 = R.상영관번호
WHERE R.고객번호 IS NULL;

127페이지 문제 18번 [판매원 데이터베이스]를 기본으로 뷰를 작성한다.
[판매원 데이터베이스]
Salesperson(name, age, salary)
Order(number, custname, salesperson,amount)
Customer(name, city, industrytype)
Order.salesperson → Salesperson.name 참조
Order.custname → Customer.name 참조

뷰 생성 질의어 15개
1. 전체 주문 통합 현황 뷰를 작성하시오
(주문 + 고객 + 영업사원 정보를 한눈에 통합 조회 뷰)

CREATE VIEW V_TOTAL_ORDER_INFO AS
SELECT O."number", O.amount, C.name AS customer_name, C.city, S.name AS salesperson_name, S.salary
FROM "Order" O
JOIN Customer C ON O.custname = C.name
JOIN Salesperson S ON O.salesperson = S.name;

2. 영업사원별 총 주문 금액 및 건수 뷰를 작성하시오
(영업사원별 실적(주문 건수, 총 매출) 집계)

CREATE VIEW V_SALESPERSON_PERFORMANCE AS
SELECT S.name, COUNT(O."number") AS total_orders, SUM(O.amount) AS total_sales
FROM Salesperson S
LEFT JOIN "Order" O ON S.name = O.salesperson
GROUP BY S.name;

3. 고객별 총 주문 금액 뷰를 작성하시오
(고객별 누적 주문 횟수와 총 구매 금액 집계 포함된 뷰)

CREATE VIEW V_CUSTOMER_ORDER_STAT AS
SELECT C.name, COUNT(O."number") AS order_count, SUM(O.amount) AS total_spent
FROM Customer C
LEFT JOIN "Order" O ON C.name = O.custname
GROUP BY C.name;

4. 도시별 주문 현황 뷰를 작성하시오
(도시(city)별 총 주문 건수와 매출 집계 포함된 뷰)

CREATE VIEW V_CITY_ORDER_STATUS AS
SELECT C.city, COUNT(O."number") AS city_orders, SUM(O.amount) AS city_sales
FROM Customer C
JOIN "Order" O ON C.name = O.custname
GROUP BY C.city;

5. 업종별 주문 통계 뷰를 작성하시오
 (산업 유형(industrytype)별 주문 건수 및 총 매출 비교 뷰)

CREATE VIEW V_INDUSTRY_STATISTICS AS
SELECT C.industrytype, COUNT(O."number") AS industry_orders, SUM(O.amount) AS industry_sales
FROM Customer C
JOIN "Order" O ON C.name = O.custname
GROUP BY C.industrytype;

6. 고액 주문 뷰 (amount 상위)를 작성하시오
 (주문 금액이 평균 이상인 고액 주문만 조회하는 뷰)

CREATE VIEW V_HIGH_VALUE_ORDERS AS
SELECT "number", amount, custname, salesperson
FROM Orders
WHERE amount >= (SELECT AVG(amount) FROM Orders);

7. 주문 실적 없는 영업사원 뷰를 작성하시오
 (한 건도 주문을 처리하지 않은 영업사원 조회 뷰)

CREATE VIEW V_INACTIVE_SALESPERSON AS
SELECT S.name, S.age, S.salary
FROM Salesperson S
LEFT JOIN Orders O ON S.name = O.salesperson
WHERE O."number" IS NULL;

8. 주문 이력 없는 고객 뷰를 작성하시오
 (등록은 되어 있지만 한 번도 주문하지 않은 고객 조회 뷰)

CREATE VIEW V_INACTIVE_CUSTOMERS AS
SELECT C.name, C.city, C.industrytype
FROM Customer C
LEFT JOIN Orders O ON C.name = O.custname
WHERE O."number" IS NULL;

9. 영업사원 급여 등급 뷰를 작성하시오
 (급여 구간별로 영업사원을 분류하는 뷰)

CREATE VIEW V_SALARY_GRADE AS
SELECT name, salary,
       CASE WHEN salary >= 80000 THEN 'High'
            WHEN salary >= 50000 THEN 'Middle'
            ELSE 'Low' END AS grade
FROM Salesperson;

10. 영업사원별 담당 고객 목록 뷰를 작성하시오
 (각 영업사원이 주문을 처리한 고객 목록(중복 제거) 생성 뷰)

CREATE VIEW V_SALESPERSON_CUSTOMERS AS
SELECT DISTINCT salesperson, custname
FROM Orders;

11. 최고 실적 영업사원 뷰를 작성하시오
 (총 주문 금액이 가장 높은 영업사원 조회하는 뷰)

CREATE VIEW V_TOP_SALESPERSON AS
SELECT name, total_sales
FROM (SELECT S.name, SUM(O.amount) AS total_sales
      FROM Salesperson S
      JOIN Orders O ON S.name = O.salesperson
      GROUP BY S.name
      ORDER BY total_sales DESC)
WHERE ROWNUM = 1;

12. 도시별 영업사원 활동 현황 뷰를 작성하시오
(어느 도시의 고객에게 얼마나 판매했는지 영업사원 기준 집계 뷰)

CREATE VIEW V_SALES_BY_CITY AS
SELECT S.name AS salesperson_name, C.city, SUM(O.amount) AS sales_in_city
FROM Salesperson S
JOIN Orders O ON S.name = O.salesperson
JOIN Customer C ON O.custname = C.name
GROUP BY S.name, C.city;
13. 영업사원 급여 대비 매출 효율 뷰를 작성하시오
(영업사원 급여 대비 총 매출 비율로 효율성 측정 뷰)

CREATE VIEW V_SALES_EFFICIENCY AS
SELECT S.name, S.salary, SUM(O.amount) AS total_sales,
       (SUM(O.amount) / S.salary) AS efficiency_ratio
FROM Salesperson S
JOIN Orders O ON S.name = O.salesperson
GROUP BY S.name, S.salary;

14. 업종별 담당 영업사원 현황 뷰를 작성하시오
 (산업 유형별로 어떤 영업사원이 활동하는지 파악)

CREATE VIEW V_INDUSTRY_SALESPERSON AS
SELECT DISTINCT C.industrytype, S.name AS salesperson_name
FROM Customer C
JOIN Orders O ON C.name = O.custname
JOIN Salesperson S ON O.salesperson = S.name;

15. 주문 금액 구간별 분류 뷰를 작성하시오
 (주문을 금액 구간으로 나누어 분류 및 통계 제공 뷰)

CREATE VIEW V_ORDER_VALUE_SEGMENT AS
SELECT "number", amount,
       CASE WHEN amount >= 10000 THEN 'Premium'
            WHEN amount >= 5000 THEN 'Standard'
            ELSE 'Basic' END AS segment
FROM Orders;

[여행사 데이터베이스] 128page 연습문제 19
 테이블 구조 확인
 Passenger(pid, pname, pgender, pcity)
 Agency(aid, aname, acity)
 Flight(fid, fdate, time, src, dest)
 Booking(pid, aid, fid, fdate)
Booking.pid → Passenger.pid 참조
Booking.aid → Agency.aid 참조
Booking.fid → Flight.fid 참조

 뷰 생성 질의어 15개
1. 전체 예약 통합 현황 뷰를 작성하시오
 (승객 + 여행사 + 항공편 정보를 한눈에 통합 조회 뷰)

CREATE VIEW V_TOTAL_BOOKING_INFO AS
SELECT B.fdate AS booking_date, P.pname, P.pgender, A.aname, F.fid, F.src, F.dest, F.time
FROM Booking B
JOIN Passenger P ON B.pid = P.pid
JOIN Agency A ON B.aid = A.aid
JOIN Flight F ON B.fid = F.fid AND B.fdate = F.fdate;

2. 승객별 예약 내역 뷰를 작성하시오
 (각 승객이 예약한 항공편과 여행사 정보 조회 뷰)

CREATE VIEW V_PASSENGER_BOOKINGS AS
SELECT P.pname, F.fid, F.src, F.dest, F.fdate, A.aname
FROM Passenger P
JOIN Booking B ON P.pid = B.pid
JOIN Flight F ON B.fid = F.fid AND B.fdate = F.fdate
JOIN Agency A ON B.aid = A.aid;

3. 여행사별 예약 건수 및 실적 뷰를 작성하시오
 (각 여행사의 총 예약 건수와 취급 항공편 수 집계 뷰)

CREATE VIEW V_AGENCY_PERFORMANCE AS
SELECT A.aname, COUNT(B.pid) AS total_bookings, COUNT(DISTINCT B.fid) AS handled_flights
FROM Agency A
LEFT JOIN Booking B ON A.aid = B.aid
GROUP BY A.aid, A.aname;

4. 항공편별 예약 승객 수 뷰를 작성하시오
 (각 항공편의 예약된 승객 수와 출발·도착지 조회 뷰)

CREATE VIEW V_FLIGHT_PASSENGER_COUNT AS
SELECT F.fid, F.fdate, F.src, F.dest, COUNT(B.pid) AS passenger_count
FROM Flight F
LEFT JOIN Booking B ON F.fid = B.fid AND F.fdate = B.fdate
GROUP BY F.fid, F.fdate, F.src, F.dest;

5. 출발지·도착지별 노선 통계 뷰를 작성하시오
 (노선(src → dest)별 운항 횟수와 총 예약 건수 집계 뷰)

CREATE VIEW V_ROUTE_STATISTICS AS
SELECT F.src, F.dest, COUNT(DISTINCT F.fid) AS flight_count, COUNT(B.pid) AS total_reservations
FROM Flight F
LEFT JOIN Booking B ON F.fid = B.fid AND F.fdate = B.fdate
GROUP BY F.src, F.dest;

6. 도시별 승객 예약 현황 뷰를 작성하시오
 (승객 거주 도시별 총 예약 건수 및 이용 현황 집계 뷰)

CREATE VIEW V_CITY_PASSENGER_STATS AS
SELECT P.pcity, COUNT(B.pid) AS total_bookings
FROM Passenger P
LEFT JOIN Booking B ON P.pid = B.pid
GROUP BY P.pcity;

7. 성별 이용 통계 뷰를 작성하시오
 (성별(pgender)에 따른 예약 건수와 이용 노선 수 비교 뷰)

CREATE VIEW V_GENDER_USAGE_STATS AS
SELECT P.pgender, COUNT(B.pid) AS total_bookings, COUNT(DISTINCT B.fid) AS distinct_flights
FROM Passenger P
JOIN Booking B ON P.pid = B.pid
GROUP BY P.pgender;

8. 예약 이력 없는 승객 뷰를 작성하시오
 (한 번도 예약하지 않은 승객 조회 (비활성 승객 관리) 뷰)

CREATE VIEW V_INACTIVE_PASSENGERS AS
SELECT pid, pname, pgender, pcity
FROM Passenger
WHERE pid NOT IN (SELECT pid FROM Booking);

9. 예약 실적 없는 여행사 뷰를 작성하시오
 (한 건도 예약을 처리하지 않은 여행사 조회 뷰)

CREATE VIEW V_INACTIVE_AGENCIES AS
SELECT aid, aname, acity
FROM Agency
WHERE aid NOT IN (SELECT aid FROM Booking);

10. 승객별 이용 여행사 목록 뷰를 작성하시오
 (각 승객이 이용한 여행사 목록 (중복 제거) 뷰)

CREATE VIEW V_PASSENGER_AGENCY_LIST AS
SELECT DISTINCT P.pname, A.aname
FROM Passenger P
JOIN Booking B ON P.pid = B.pid
JOIN Agency A ON B.aid = A.aid;

11. 동일 출발·도착지 왕복 노선 뷰를 작성하시오
 (왕복 운항이 가능한 노선 쌍(A→B, B→A) 조회 뷰)

CREATE VIEW V_ROUND_TRIP_ROUTES AS
SELECT DISTINCT F1.src, F1.dest
FROM Flight F1
WHERE EXISTS (
    SELECT 1 FROM Flight F2 
    WHERE F1.src = F2.dest AND F1.dest = F2.src
);

12. 여행사별 담당 승객 상세 뷰를 작성하시오
 (여행사별로 담당한 승객 정보와 이용 항공편 상세 조회 뷰)

CREATE VIEW V_AGENCY_CUSTOMER_DETAILS AS
SELECT A.aname, P.pname, F.fid, F.src, F.dest, B.fdate
FROM Agency A
JOIN Booking B ON A.aid = B.aid
JOIN Passenger P ON B.pid = P.pid
JOIN Flight F ON B.fid = F.fid AND B.fdate = F.fdate;

13. 날짜별 예약 및 항공편 현황 뷰를 작성하시오
 (날짜별 총 예약 건수와 운항 항공편 수 집계 뷰)

CREATE VIEW V_DAILY_FLIGHT_STATS AS
SELECT fdate, COUNT(DISTINCT fid) AS flight_count, COUNT(*) AS booking_count
FROM Booking
GROUP BY fdate;

14. 다중 항공편 이용 승객 뷰를 작성하시오
 (2개 이상의 항공편을 예약한 승객 조회 (자주 이용 고객) 뷰)

CREATE VIEW V_FREQUENT_FLYERS AS
SELECT P.pid, P.pname, COUNT(B.fid) AS booking_count
FROM Passenger P
JOIN Booking B ON P.pid = B.pid
GROUP BY P.pid, P.pname
HAVING COUNT(B.fid) >= 2;

15. 승객-여행사 동일 도시 예약 뷰를 작성하시오
 (승객의 거주 도시와 여행사 위치가 같은 예약 조회 뷰)

CREATE VIEW V_LOCAL_CITY_BOOKINGS AS
SELECT P.pname, A.aname, P.pcity AS common_city, F.fid
FROM Booking B
JOIN Passenger P ON B.pid = P.pid
JOIN Agency A ON B.aid = A.aid
JOIN Flight F ON B.fid = F.fid AND B.fdate = F.fdate
WHERE P.pcity = A.acity;

[기업프로젝트 데이터베이스] 128page 20번 문제
Employee(empno, name, phoneno, address, sex, position, deptno)
Department(deptno, deptname, manager)
Project(projno,proname,deptno)
Works(empno, projno, hours_worked)
Employee.deptno → Department.deptno 참조
Project.deptno → Department.deptno 참조
Works.empno → Employee.empno 참조
Works.projno → Project.projno 참조

[뷰 생성 질의어]
1. 직원 전체 정보 통합 뷰를 작성하시오
 (직원 정보와 소속 부서명을 함께 조회하는 뷰)

CREATE VIEW V_EMP_DEPT_INFO AS
SELECT E.empno, E.name, E.phoneno, E.position, D.deptname
FROM Employee E
JOIN Department D ON E.deptno = D.deptno;

2. 직원별 프로젝트 참여 현황 뷰를 작성하시오
 (직원이 참여 중인 프로젝트명과 투입 시간 조회하는 뷰)

CREATE VIEW V_EMP_PROJ_STATUS AS
SELECT E.name AS emp_name, P.PROJNAME, W.hours_worked
FROM Employee E
JOIN Works W ON E.empno = W.empno
JOIN Project P ON W.projno = P.projno;

3. 부서별 직원 수 및 현황 뷰를 작성하시오
 (부서별 소속 직원 수와 관리자 정보 집계 뷰)

CREATE VIEW V_DEPT_EMP_COUNT AS
SELECT D.deptno, D.deptname, D.manager, COUNT(E.empno) AS emp_count
FROM Department D
LEFT JOIN Employee E ON D.deptno = E.deptno
GROUP BY D.deptno, D.deptname, D.manager;

4. 프로젝트별 참여 직원 및 총 투입 시간 뷰를 작성하시오
 (각 프로젝트에 참여한 직원 수와 총 근무 시간 집계 뷰)

CREATE VIEW V_PROJ_STATISTICS AS
SELECT P.projno, P.PROJNAME, COUNT(W.empno) AS participant_count, SUM(W.hours_worked) AS total_hours
FROM Project P
LEFT JOIN Works W ON P.projno = W.projno
GROUP BY P.projno, P.PROJNAME;

5. 직원별 총 근무 시간 뷰를 작성하시오
 (직원이 전체 프로젝트에 투입한 총 시간 집계 뷰)

CREATE VIEW V_EMP_TOTAL_HOURS AS
SELECT E.empno, E.name, SUM(W.hours_worked) AS total_work_hours
FROM Employee E
JOIN Works W ON E.empno = W.empno
GROUP BY E.empno, E.name;

6. 부서별 프로젝트 현황 뷰를 작성하시오
 (각 부서가 담당하는 프로젝트 수와 총 투입 시간 집계 뷰)

CREATE VIEW V_DEPT_PROJ_STATUS AS
SELECT D.deptname, COUNT(DISTINCT P.projno) AS proj_count, SUM(W.hours_worked) AS dept_total_hours
FROM Department D
LEFT JOIN Project P ON D.deptno = P.deptno
LEFT JOIN Works W ON P.projno = W.projno
GROUP BY D.deptname;

7. 프로젝트에 참여하지 않는 직원 뷰를 작성하시오
 (어떤 프로젝트에도 투입되지 않은 직원 조회 뷰)

CREATE VIEW V_FREE_EMPLOYEES AS
SELECT empno, name, position
FROM Employee
WHERE empno NOT IN (SELECT empno FROM Works);

8. 성별 프로젝트 참여 통계 뷰를 작성하시오
 (성별(sex)에 따른 프로젝트 참여 수와 평균 근무 시간 비교 뷰)

CREATE VIEW V_GENDER_PROJ_STATS AS
SELECT E.sex, COUNT(W.projno) AS total_participations, AVG(W.hours_worked) AS avg_hours
FROM Employee E
JOIN Works W ON E.empno = W.empno
GROUP BY E.sex;

9. 관리자(Manager) 직원 상세 뷰를 작성하시오
 (부서 관리자로 지정된 직원의 상세 정보 조회 뷰)

CREATE VIEW V_MANAGER_DETAILS AS
SELECT E.empno, E.name, E.position, D.deptname
FROM Employee E
JOIN Department D ON E.empno = D.manager;

10. 직책별 프로젝트 참여 현황 뷰를 작성하시오
 (직책(position)별 총 프로젝트 참여 건수와 평균 투입 시간 뷰)

CREATE VIEW V_POSITION_PROJ_STATS AS
SELECT E.position, COUNT(W.projno) AS total_count, AVG(W.hours_worked) AS avg_hours
FROM Employee E
JOIN Works W ON E.empno = W.empno
GROUP BY E.position;

11. 다중 프로젝트 참여 직원 뷰를 작성하시오
 (2개 이상의 프로젝트에 참여 중인 직원 조회 뷰)

CREATE VIEW V_MULTI_PROJ_EMPS AS
SELECT E.empno, E.name, COUNT(W.projno) AS proj_count
FROM Employee E
JOIN Works W ON E.empno = W.empno
GROUP BY E.empno, E.name
HAVING COUNT(W.projno) >= 2;

12. 부서 내 프로젝트 참여 직원 상세 뷰를 작성하시오
(같은 부서 소속 직원이 해당 부서 프로젝트에 참여하는 현황 뷰)

CREATE VIEW V_INTRA_DEPT_PROJ AS
SELECT E.name AS emp_name, D.deptname, P.PROJNAME
FROM Employee E
JOIN Department D ON E.deptno = D.deptno
JOIN Project P ON D.deptno = P.deptno
JOIN Works W ON E.empno = W.empno AND P.projno = W.projno;

13. 타 부서 프로젝트 참여 직원 뷰를 작성하시오
 (자신의 소속 부서가 아닌 타 부서 프로젝트에 참여하는 직원 뷰)

CREATE VIEW V_INTER_DEPT_PROJ AS
SELECT E.name AS emp_name, E.deptno AS emp_dept, P.deptno AS proj_dept, P.PROJNAME
FROM Employee E
JOIN Works W ON E.empno = W.empno
JOIN Project P ON W.projno = P.projno
WHERE E.deptno <> P.deptno;

14. 고투입 시간 직원 뷰 (평균 이상 근무)를 작성하시오
 (프로젝트 평균 투입 시간보다 많이 근무한 직원 조회 뷰)

CREATE VIEW V_HARD_WORKING_EMPS AS
SELECT E.name, W.hours_worked
FROM Employee E
JOIN Works W ON E.empno = W.empno
WHERE W.hours_worked > (SELECT AVG(hours_worked) FROM Works);

15. 프로젝트 미배정 부서 뷰를 작성하시오
 (담당 프로젝트가 하나도 없는 부서 조회 뷰)

CREATE VIEW V_DEPT_WITHOUT_PROJ AS
SELECT deptno, deptname
FROM Department
WHERE deptno NOT IN (SELECT deptno FROM Project);
